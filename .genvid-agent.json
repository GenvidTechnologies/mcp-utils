{
  "project": {
    "name": "@genvidtech/mcp-utils",
    "description": "Dependency-light TypeScript utilities for building MCP servers in the Genvid monorepo.",
    "languages": ["typescript"]
  },
  "commands": {
    "test": "npm run test",
    "lint": "npm run lint",
    "build": "npm run build",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "repo": {
    "host": "github",
    "default_branch": "main"
  },
  "bugTracker": {
    "kind": "github",
    "actionQuery": "gh issue list --state open -L 200 --json number,title,labels,body,assignees",
    "comparisonQuery": "gh issue list --state all -L 500 --json number,title,labels,state",
    "readOne": "gh issue view {id} --json number,title,body,labels,comments",
    "triagedLabel": "triaged",
    "needsInfoLabel": "needs-info"
  },
  "features": {},
  "paths": {}
}
