{
	"name": "@genvid/mcp-utils",
	"version": "0.2.0",
	"description": "Dependency-light TypeScript utilities for building MCP (Model Context Protocol) servers: concurrency control, file-change tracking, text pagination, path/filesystem helpers, and MCP response/error/annotation helpers.",
	"license": "MIT-0",
	"author": "Genvid Technologies, inc. <support@genvidtech.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/genvid-holdings/genvid-mcp-utils.git"
	},
	"homepage": "https://github.com/genvid-holdings/genvid-mcp-utils#readme",
	"bugs": "https://github.com/genvid-holdings/genvid-mcp-utils/issues",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"typescript",
		"utilities"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"prepack": "npm run build",
		"test": "mocha --timeout 5000 --import=tsx --require ./test/setup.ts 'test/**/*.test.ts' --exit",
		"lint": "eslint --ext .ts --max-warnings 0 src/ test/",
		"typecheck": "tsc -p tsconfig.test.json --noEmit"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"mocha": "^10.4.0",
		"chai": "^5.1.1",
		"@types/node": "^22.0.0",
		"@types/mocha": "^10.0.6",
		"@types/chai": "^4.3.16",
		"tsx": "^4.21.0",
		"typescript": "^5.4.5",
		"eslint": "^8.36.0",
		"@typescript-eslint/eslint-plugin": "^7.10.0",
		"@typescript-eslint/parser": "^7.10.0",
		"eslint-config-prettier": "^8.7.0"
	}
}
